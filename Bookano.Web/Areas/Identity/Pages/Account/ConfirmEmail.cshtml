@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm email";
}

<div class="d-flex flex-column flex-root">
    <!--begin::Page bg image-->
    <style>
            body {
                background-image: url('/assets/imgs/bg10.jpeg');
            }

            [data-bs-theme="dark"] body {
                background-image: url('/assets/imgs/bg10-dark.jpeg');
            }
    </style>
    <!--end::Page bg image-->
    <!--begin::Authentication - Signup Welcome Message -->
    <div class="d-flex flex-column flex-center flex-column-fluid">
        <!--begin::Content-->
        <div class="d-flex flex-column flex-center text-center p-10">
            <!--begin::Wrapper-->
            <div class="card card-flush w-lg-650px py-5">
                <div class="card-body py-15 py-lg-20">
                
                    <!--begin::Logo-->
                    <div class="mb-7">
                        <a href="/" class="">
                            <img alt="Logo" src="~/assets/imgs/logo.png" class="h-150px" style="margin-bottom:-35px">
                        </a>
                    </div>
                    <!--end::Logo-->
                    <!--begin::Title-->
                    <h1 class="fw-bolder text-gray-900 mb-5">
                        Welcome to Bookano
                    </h1>
                    <!--end::Title-->
                    <!--begin::Text-->
                    <div class="fw-semibold fs-6 text-gray-500 mb-5">
                        Manage your books, authors, and categories efficiently
                        <br>
                        Keep your library data organized and up to date
                    </div>
                    <!--end::Text-->
                    <!--begin::Illustration-->
                    <div class="mb-0">
                        <img />
                        <img src="~/assets/imgs/Welcome-rafiki.svg" class="mw-100 mh-250px theme-light-show" alt="">
                        <img src="~/assets/imgs/Welcome-rafiki.svg" class="mw-100 mh-250px theme-dark-show" alt="">
                    </div>
                    <!--end::Illustration-->
                    <!--begin::Link-->
                    <div class="mb-0">
                        <a asp-page="./Login" class="btn btn-md btn-primary">Login Now</a>
                    </div>
                    <!--end::Link-->

                </div>
            </div>
            <!--end::Wrapper-->
        </div>
        <!--end::Content-->
    </div>
    <!--end::Authentication - Signup Welcome Message-->
</div>