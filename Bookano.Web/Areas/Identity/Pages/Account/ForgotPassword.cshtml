@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}


<div class="d-flex flex-column flex-root">
    <!--begin::Page bg image-->
    <style>
            body {
                background-image: url('/assets/imgs/bg10.jpeg');
            }

            [data-bs-theme="dark"] body {
                background-image: url('/assets/imgs/bg10-dark.jpeg');
            }
    </style>
    <!--end::Page bg image-->
    <!--begin::Authentication - Password reset -->
    <div class="d-flex flex-column flex-lg-row flex-md-column-fluid my-auto">
        <!--begin::Aside-->
        <div class="d-flex flex-lg-row-fluid d-none d-md-flex ">
            <!--begin::Content-->
            <div class="d-flex flex-column flex-center pb-0 pb-lg-10 p-10 w-100">
                <!--begin::Image-->
                
                <img class="theme-light-show mx-auto mw-100 w-200px w-lg-350px mb-2 "
                     src="~/assets/imgs/Forgot password-bro.svg" alt="" />
                <img class="theme-dark-show mx-auto mw-100 w-200px w-lg-350px mb-2"
                     src="~/assets/imgs/Forgot password-bro.svg" alt="" />
                <!--end::Image-->
                <partial name="_PreAuthIntro" />
            </div>
            <!--end::Content-->
        </div>
        <!--begin::Aside-->
        <!--begin::Body-->
        <div class=" d-flex flex-column-fluid flex-lg-row-auto justify-content-center justify-content-lg-end p-6 p-md-12">
            <!--begin::Wrapper-->
            <div class="w-100 bg-body d-flex flex-column flex-center rounded-4 w-md-600px p-5 p-md-10">
                <div class="d-flex flex-lg-row-fluid d-md-none  ">
                    <!--begin::Content-->
                    <div class="d-flex flex-column flex-center pb-0 pb-lg-10 p-10 w-100">
                        <!--begin::Image-->

                        <img class="theme-light-show mx-auto mw-100 w-200px w-lg-350px mb-2 "
                             src="~/assets/imgs/Forgot password-bro.svg" alt="" />
                        <img class="theme-dark-show mx-auto mw-100 w-200px w-lg-350px mb-2"
                             src="~/assets/imgs/Forgot password-bro.svg" alt="" />
                        <!--end::Image-->
                        <partial name="_PreAuthIntro" />
                    </div>
                    <!--end::Content-->
                </div>
                <!--begin::Content-->
                <div class=" w-100 d-flex flex-center flex-column align-items-stretch h-lg-100 w-md-400px">
                    <!--begin::Wrapper-->
                    <div class="d-flex flex-center flex-column flex-column-fluid pb-15 pb-lg-20">
        
                        <!--begin::Form-->
                        <form class="form w-100 fv-plugins-bootstrap5 fv-plugins-framework" novalidate="novalidate" method="post" >
                            <!--begin::Heading-->
                            <div class="text-center mb-10">
                                <!--begin::Title-->
                                <h1 class="text-gray-900 fw-bolder mb-3">
                                    Forgot Password ?
                                </h1>
                                <!--end::Title-->
                                <!--begin::Link-->
                                <div class="text-gray-500 fw-semibold fs-6">
                                    Enter your email to reset your password.
                                </div>
                                <!--end::Link-->
                                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                            </div>
                            <!--begin::Heading-->
                            <!--begin::Input group--->
                            <div class="fv-row mb-8 fv-plugins-icon-container">
                                <!--begin::Email-->
                                <input asp-for="Input.Email" type="text" placeholder="Email"  autocomplete="off" class="form-control bg-transparent">
                                <!--end::Email-->
                                <span asp-validation-for="Input.Email" class="fv-plugins-message-container fv-plugins-message-container--enabled invalid-feedback"></span>
                            </div>

                            <!--begin::Actions-->
                            <div class="d-flex flex-column flex-md-row flex-wrap justify-content-center pb-lg-0">
                                <button type="submit" id="kt_password_reset_submit" class="btn btn-primary mb-4 mb-md-0 me-md-4">
            
                                    <!--begin::Indicator label-->
                                    <span class="indicator-label">
                                        Reset Password
                                    </span>
                                    <!--end::Indicator label-->
                                    <!--begin::Indicator progress-->
                                    <span class="indicator-progress">
                                        Please wait...    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                    </span>
                                    <!--end::Indicator progress-->
                                </button>

                                <a asp-page="./Login" class="btn btn-light">Cancel</a>
                            </div>
                            <!--end::Actions-->
                        </form>
                        <!--end::Form-->
                    </div>
                    <!--end::Wrapper-->
                </div>
                <!--end::Content-->
            </div>
            <!--end::Wrapper-->
        </div>
        <!--end::Body-->
    </div>
    <!--end::Authentication - Password reset-->
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
