{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.MSSqlServer"
    ],

    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },

    "Properties": {
      "Application": "Bookano.Web"
    },

    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],

    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/bookano-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Json.JsonFormatter"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/bookano-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "AutoCreateSqlTable": true,
          "ConnectionString": "",
          "SchemaName": "logging",
          "TableName": "Logs",
          "RestrictToMinimumLevel": "Error",
          "ColumnOptions": {
            "AdditionalColumns": [
              {
                "ColumnName": "UserId",
                "DataType": "nvarchar",
                "DataLength": 450
              },
              {
                "ColumnName": "UserName",
                "DataType": "nvarchar",
                "DataLength": 256
              }
            ]
          }
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "CloudinarySettings": {
    "Cloud": "",
    "APIKey": "",
    "APISecret": ""
  },
  "MailSettings": {
    "Email": "",
    "DisplayName": "Bookano",
    "Password": "",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "DevelopmentOverrideRecipient": ""
  },
  "WhatsAppConfigurations": {
    "PhoneNumberId": "",
    "AccessToken": ""
  }
}