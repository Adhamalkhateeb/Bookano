@model RentalsReportViewModel
@{
    ViewData["Title"] = "Rentals Report";
}

<div class="card mb-4">
    <div class="card-body">
        <form id="Filters" method="get" asp-controller="Reports" class="js-excelued-validation">
            <input type="hidden" id="PageNumber" name="PageNumber" value="1" />
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-5">
                        <label asp-for="Duration" class="form-label">Duration: </label>
                        <input type="text" asp-for="Duration" class="form-control form-control-solid js-date-range" placeholder="Pick date range" autocomplete="off" />
                        <span asp-validation-for="Duration" class="text-danger mt-2"></span>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Show Report</button>
        </form>
    </div>
</div>
@if (Model.Rentals is not null)
{
    <div class="card mb-4">
        <div class="card-header">
            <div class="card-title">
                <span>Rentals</span>
            </div>
            @if (Model.Rentals.Items.Any())
            {
                <div class="card-toolbar gap-3">
                    <a class="btn btn-light-success w-100 w-md-auto" asp-action="ExportRentalsToExcel"
                       asp-route-duration="@Context.Request.Query["Duration"]">
                        <i class="fa-solid fa-file-excel"></i>
                        Export to Excel
                    </a>
                    <a class="btn btn-light-danger w-100 w-md-auto" asp-action="ExportRentalsToPDF"
                       asp-route-duration="@Context.Request.Query["Duration"]">
                        <i class="fa-solid fa-file-pdf"></i>
                        Export to PDF
                    </a>
                </div>
            }
        </div>
        <div class="card-body">
            <partial name="_Pagination" model="new PaginatedViewModel { PageNumber = Model.Rentals.PageNumber, TotalPages = Model.Rentals.TotalPages }" />
            @if (Model.Rentals.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table table-row-dashed table-row-gray-300 gy-2 align-middle js-responsive-table">
                        <thead>
                            <tr class="fw-bold fs-5 text-white bg-black ">
                                <th class="ps-4 rounded-start">Subscriber ID</th>
                                <th>Subscriber Name</th>
                                <th>Subscriber Mobile</th>
                                <th>Book Title</th>
                                <th>Book Authors</th>
                                <th>Book Serial</th>
                                <th>Rental Date</th>
                                <th>End Date</th>
                                <th>Return Date</th>
                                <th class="pe-4 rounded-end">Extended On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rental in Model.Rentals.Items)
                            {
                                <tr>
                                    <td data-label="Subscriber ID" class="ps-md-4">@rental.SubscriberId</td>
                                    <td data-label="Subscriber Name">@rental.SubscriberName</td>
                                    <td data-label="Subscriber Mobile">@rental.SubscriberMobile</td>
                                    <td data-label="Book Title">@rental.BookTitle</td>
                                    <td data-label="Book Authors">@string.Join(", ", rental.BookAuthors!)</td>
                                    <td data-label="Serial Number">@rental.BookSerialNumber</td>
                                    <td data-label="Rental Date">@rental.RentalDate.ToString("d MMM, yyyy")</td>
                                    <td data-label="End Date">@rental.EndDate.ToString("d MMM, yyyy")</td>
                                    <td data-label="Return Date">@(rental.ReturnDate is null ? "-" : rental.ReturnDate.Value.ToString("d MMM, yyyy"))</td>
                                    <td data-label="Extended On" class="pe-4">@(rental.ExtendedOn is null ? "-" : rental.ExtendedOn.Value.ToString("d MMM, yyyy"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {

                <h5>No rentals during this duration</h5>
            }

        </div>
    </div>
}

@section Scripts {
    <script src="~/js/reports.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}