@model AuthorViewModel

<tr>
    <td>@Model.Name</td>
    <td>
        <span class="badge badge-light-@(Model.IsDeleted ? "danger" : "success") js-status">
            @(Model.IsDeleted ? "Deleted" : "Available")
        </span>
    </td>
    <td>@Model.CreatedOnUtc.ToLocalTime().ToString("yyyy/MM/dd hh:mm tt")</td>
    <td class="js-updated-on">@(Model.LastUpdatedOnUtc.HasValue? Model.LastUpdatedOnUtc.Value.ToLocalTime().ToString("yyyy/MM/dd hh:mm tt") : "")</td>
    <td>
        <button type="button" class="btn btn-sm btn-icon btn-color-primary btn-active-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
            <i class="fa-regular fa-pen-to-square fs-xl-2 "></i>
        </button>
        <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px py-3" data-kt-menu="true" >
            <!--begin::Menu item-->
            <div class="menu-item px-3">
                <a href="javascript:;" data-url="/Authors/Edit/@Model.Id"
                       data-title="Edit Author"
                       data-mode="true"
                       class="menu-link flex-stack px-3 js-render-modal">
                    Edit
                </a>
            </div>
            <!--end::Menu item-->
            <!--begin::Menu item-->
            <div class="menu-item px-3">
                <a href="javascript:;" class="menu-link px-3 js-toggle-status"
                       data-url="/Authors/ToggleStatus/@Model.Id">
                    Toggle status
                </a>
            </div>
            <!--end::Menu item-->
        </div>
    </td>
</tr>