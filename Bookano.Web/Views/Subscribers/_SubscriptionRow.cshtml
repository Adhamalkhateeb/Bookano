@model SubscriptionViewModel
<tr class="table-row-gray-300">
    <td data-label="Start Date" class="ps-0 ps-md-4">
        @Model.StartDate.ToString("d MMM, yyyy")
    </td>
    <td data-label="End Date">
        @Model.EndDate.ToString("d MMM, yyyy")
    </td>
    <td data-label="Status">
        @if (!string.IsNullOrEmpty(Model.Status))
        {
            <span class="badge badge-light-@(Model.Status == SubscriptionStatus.Active ? "success" : "warning") fs-7 fw-bold">
                @Model.Status
            </span>
        }
    </td>

    <td data-label="Created On" class="js-created-on" data-utc="@Model.CreatedOnUtc.ToString("o")">
    </td>
</tr>