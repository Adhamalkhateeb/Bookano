@model IEnumerable<BookViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<!--begin::Main-->
<!--begin::Root-->
<div class="d-flex flex-column flex-root page-bg">
    <!--begin::Page-->
    <div class="page launcher sidebar-enabled d-flex flex-row flex-column-fluid me-lg-5" id="kt_page">
        <!--begin::Content-->
        <div class="d-flex flex-row-fluid">
            <!--begin::Container-->
            <div class="d-flex flex-column flex-row-fluid align-items-center">
                <!--begin::Menu-->
                <div class="d-flex flex-column flex-column-fluid mb-5 mb-lg-10">
                    <!--begin::Brand-->
                    <div class="d-flex flex-stack pt-10 pt-lg-0 mb-5 mb-lg-0 h-lg-225px justify-content-between justify-content-lg-center px-10 px-lg-0">
                        <!--begin::Sidebar toggle-->
                        <div class="btn btn-icon btn-active-color-primary w-50px h-50px d-lg-none bg-white bg-opacity-25 rounded"
                             id="kt_sidebar_toggle">
                            <i class="fa-solid fa-sliders fs-1 text-white"></i>
                        </div>
                        <!--end::Sidebar toggle-->
                        <!--begin::Logo-->
                        <a href="/" >
                            <img alt="Logo" src="~/assets/imgs/logo.png"
                                 class="h-150px h-lg-250px mb-n5" />
                        </a>
                        <!--end::Logo-->
                        <!--begin::Empty div for flex spacing-->
                        <div class="w-50px d-lg-none"></div>
                        <!--end::Empty div-->
                    </div>
                    <!--end::Brand-->

                    <!--begin::Row-->
                    <div class="row g-7 w-xxl-850px justify-content-center min-h-500px mx-0 px-5 px-lg-0">
                        <!--begin::Col-->
                        <div class="col-12 col-lg-6 col-xxl-5 mb-5 mb-lg-0">
                            <!--begin::Card-->
                            <div class="card border-0 shadow-none h-lg-100 " style="background-color: #A838FF">
                                <!--begin::Card body-->
                                <div class="card-body d-flex flex-column flex-center pb-0 pt-20">
                                    <!--begin::Wrapper-->
                                    <div class="px-10 mb-10 align-items-center  d-flex flex-column">
                                        <!--begin::Heading-->
                                        <h2 class="text-white text-center mb-2 fw-bolder ttext-center text-uppercase mb-6">
                                            Bookano Staff
                                        </h2>
                                        <!--end::Heading-->
                                        <!--begin::Link-->
                                        <a asp-controller="Dashboard" asp-action="Index"
                                           class="btn btn-hover-rise text-info bg-white bg-opacity-75 text-uppercase fs-7 fw-bold">
                                            Go To Dashboard
                                        </a>
                                        <!--end::Link-->
                                    </div>
                                    <!--end::Wrapper-->
                                    <!--begin::Illustrations-->
                                    <img class="mw-100 h-200px mx-auto mb-lg-n18" src="~/assets/imgs/Staff.svg" />
                                    <!--end::Illustrations-->
                                </div>
                                <!--end::Card body-->
                            </div>
                            <!--end::Card-->
                        </div>
                        <!--end::Col-->
                        <!--begin::Col-->
                        <div class="col-12 col-lg-6 col-xxl-5 mb-10 mb-lg-0">
                            <!--begin::Card-->
                            <div class="card border-0 shadow-none h-lg-100 bg-primary">
                                <!--begin::Card body-->
                                <div class="card-body d-flex flex-column flex-center pb-0 pt-20">
                                    <!--begin::Wrapper-->
                                    <div class="px-10 mb-10 align-items-center  d-flex flex-column">
                                        <!--begin::Heading-->
                                        <h2 class="text-white text-center mb-2 fw-bolder ttext-center text-uppercase mb-6">
                                            Find a book
                                        </h2>
                                        <!--end::Heading-->
                                        <!--begin::Link-->
                                        <a asp-controller="Search" asp-action="Index"
                                           class="btn btn-hover-rise text-info bg-white bg-opacity-75 text-uppercase fs-7 fw-bold">
                                            Go to search
                                        </a>
                                        <!--end::Link-->
                                    </div>
                                    <!--end::Wrapper-->
                                    <!--begin::Illustrations-->
                                    <img class="mw-100 h-200px mx-auto mb-lg-n18" src="~/assets/imgs/search-rafiki.svg" />
                                    <!--end::Illustrations-->
                                </div>
                                <!--end::Card body-->
                            </div>
                            <!--end::Card-->
                        </div>
                        <!--end::Col-->
                    </div>
                    <!--end::Row-->
                </div>
                <!--end::Menu-->
            </div>
            <!--begin::Content-->
        </div>
        <!--begin::Content-->
        <!--begin::Sidebar-->
        <div id="kt_sidebar" class="sidebar px-5 py-5 py-lg-8 px-lg-11" data-kt-drawer="true"
             data-kt-drawer-name="sidebar" data-kt-drawer-activate="{default: true, lg: false}"
             data-kt-drawer-overlay="true" data-kt-drawer-width="375px" data-kt-drawer-direction="end"
             data-kt-drawer-toggle="#kt_sidebar_toggle">

            <!--begin::Header-->
            <div class="d-flex flex-stack mb-5 mb-lg-8" id="kt_sidebar_header">
                <!--begin::Title-->
                <h2 class="text-white">Recently Added Books</h2>
                <!--end::Title-->
                <!--begin::Menu-->
            </div>
            <!--end::Header-->
            <!--begin::Body-->
            <div class="mb-5 mb-lg-8" id="kt_sidebar_body">
                <!--begin::Scroll-->
                <div class="hover-scroll-y me-n6 pe-6" id="kt_sidebar_body" data-kt-scroll="true"
                     data-kt-scroll-height="auto"
                     data-kt-scroll-dependencies="#kt_sidebar_header, #kt_sidebar_footer"
                     data-kt-scroll-wrappers="#kt_page, #kt_sidebar, #kt_sidebar_body" data-kt-scroll-offset="0">
                    <div class="pb-20">
                        @foreach (var book in Model)
                        {

                            <!--begin::Item-->
                            <a class="d-flex flex-stack @(book == Model.Last() ? "mb-10" : "mb-5")" asp-controller="Search" asp-action="BookDetails" asp-route-bookKey="@book.Key">
                                <!--begin::Symbol-->
                                <div class="symbol  symbol-60px me-4">
                                    <img src="@(book.ImageUrl ?? "/images/books/no-image-cover.png")" alt="@book.Title" class="h-100px">
                                </div>
                                <!--end::Symbol-->
                                <!--begin::Section-->
                                <div class="d-flex align-items-center flex-row-fluid flex-wrap">
                                    <!--begin:Author-->
                                    <div class="flex-grow-1 me-2">
                                        <h5 class="text-white text-hover-primary fs-5 fw-bolder">@book.Title</h5>

                                        <span class="text-gray-700 fw-semibold d-block fs-6">@(string.Join(", ", book.Authors))</span>
                                    </div>
                                    <!--end:Author-->
                                </div>
                                <!--end::Section-->
                            </a>
                            <!--end::Item-->
                            @if (book != Model.Last())
                            {
                                <!--begin::Separator-->
                                <div class="separator separator-dashed my-5"></div>
                                <!--end::Separator-->
                            }
                        }
                    </div>
                </div>
                <!--end::Scroll-->
            </div>
            <!--end::Body-->
        </div>
        <!--end::Sidebar-->
    </div>
    <!--end::Page-->
</div>
<!--end::Root-->
<!--end::Main-->





