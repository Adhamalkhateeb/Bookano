@model PaginatedViewModel
@if (Model.TotalPages > 1)
{

    <ul class="pagination pagination-circle pagination-outline justify-content-start mb-4">
        @if (Model.PageNumber - 3 > 1)
        {
            <li class="page-item first m-1">
                <a href="javascript:;" class="page-link px-0" data-page-number="1">
                    <i class="fa-solid fa-angles-left fs-2"></i>
                </a>
            </li>
        }
        @if (Model.HasPreviousPage)
        {
            <li class="page-item previous m-1">
                <a href="javascript:;" class="page-link px-0" data-page-number="@(Model.PageNumber - 1)">
                    <i class="fa-solid fa-chevron-left fs-2"></i>
                </a>
            </li>
        }

        @for (int i = Math.Max(Model.PageNumber - 3, 1); i <= Math.Min(Model.TotalPages, Model.PageNumber + 3); i++)
        {
            <li class="page-item m-1 @(Model.PageNumber == i ? "active" : "")">
                <a href="#" class="page-link" data-page-number="@i">@i</a>
            </li>
        }
        @if (Model.HasNextPage)
        {
            <li class="page-item next m-1">
                <a href="javascript:;" class="page-link px-0" data-page-number="@(Model.PageNumber + 1)">
                    <i class="fa-solid fa-chevron-right fs-2"></i>
                </a>
            </li>
        }
        @if (Model.PageNumber + 3 < Model.TotalPages)
        {
            <li class="page-item last m-1">
                <a href="javascript:;" class="page-link px-0" data-page-number="@Model.TotalPages">
                    <i class="fa-solid fa-angles-right fs-2"></i>
                </a>
            </li>
        }

    </ul>
}