@model BookFormViewModel
@* @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery *@
@{
    ViewData["Title"] = $" {(Model?.Id > 0 ? "Edit" : "Create")} Book";
}

<form method="post" asp-controller="Books" enctype="multipart/form-data">
    <div class="card shadow-sm ">
        <div class="card-header">
            <h3 class="card-title">@(Model?.Id > 0 ? "Edit" : "Add") Book</h3>
        </div>
        <div class="card-body">
        
            @if (Model?.Id > 0)
            {
                <input type="hidden" asp-for="Id" />
            }
            <div class="mb-10">
                <style>
                                    .image-input-placeholder {
                                        background-image: url('/images/no-image-placeholder-125x200.svg');
                                    }
                </style>
                <div id="book_image_input" class="image-input image-input-placeholder @(string.IsNullOrEmpty(Model?.ImageUrl) ? "image-input-empty" : "image-input-filled")"
                     data-kt-image-input="true">

                    <!-- WRAPPER -->
                    <div class="image-input-wrapper w-125px h-200px"
                         style="@(string.IsNullOrEmpty(Model?.ImageThumbnailUrl) ? "" : $"background-image: url('{Model.ImageThumbnailUrl}')")">
                    </div>


                    <label class="btn btn-icon btn-circle btn-color-muted btn-active-color-primary w-25px h-25px bg-body shadow"
                           data-kt-image-input-action="change"
                           data-bs-dismiss="click">
                        <i class="fa-solid fa-pencil"></i>
                        <input type="file" asp-for="Image" accept=".png, .jpg, .jpeg, .webp" />
                        <input type="hidden" name="avatar_remove" />
                    </label>

                    <span class="btn btn-icon btn-circle btn-color-muted btn-active-color-primary w-25px h-25px bg-body shadow"
                          data-kt-image-input-action="cancel"
                          data-bs-dismiss="click">
                        <i class="fa-solid fa-x"></i>
                    </span>

                    <span class="btn btn-icon btn-circle btn-color-muted btn-active-color-primary w-25px h-25px bg-body shadow"
                          data-kt-image-input-action="remove"
                          data-bs-dismiss="click">
                        <i class="fa-solid fa-x"></i>
                    </span>
                </div>
                <input type="hidden" asp-for="RemoveImage" id="RemoveImage" />
                <div class="form-text">Allowed file types: [png, jpeg, jpg, webp] - maximum 2MB </div>
                <span asp-validation-for="Image" class="text-danger d-block"></span>
                <!--end::Image input-->
            </div>
            <div class="row">
                <div class="col-md-5">
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class="form-floating mb-2">
                                    <input asp-for="Isbn" type="text" class="form-control form-control-solid" placeholder=" " />
                                    <label asp-for="Isbn" class="form-label"></label>
                                </div>
                                <span asp-validation-for="Isbn" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class="form-floating mb-2">
                                    <input asp-for="Title" type="text" class="form-control form-control-solid" placeholder=" " />
                                    <label asp-for="Title" class="form-label"></label>
                                </div>
                                <span asp-validation-for="Title" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class=" mb-2">
                                    <select asp-for="SelectedAuthors" class="form-select form-select-solid js-select2" asp-items="Model?.Authors" data-placeholder="Select authors">
                                        <option></option>
                                    </select>
                                </div>
                                <span asp-validation-for="SelectedAuthors" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class=" mb-2">
                                    <select asp-for="SelectedCategories" class="form-select form-select-solid  js-select2" asp-items="Model?.Categories" multiple data-placeholder="Select Categories">
                                        <option></option>
                                    </select>
                                </div>
                                <span asp-validation-for="SelectedCategories" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class="form-floating mb-2">
                                    <select asp-for="PublisherId" class="form-select form-select-solid js-select2" asp-items="Model?.Publishers" data-placeholder="Select an publisher">
                                        <option value="">Select publisher</option>
                                    </select>
                                    <label asp-for="PublisherId" class="form-label"></label>
                                </div>
                                <span asp-validation-for="PublisherId" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class=" mb-2">
                                    <label asp-for="PublishingDate" class="form-label"></label>
                                    <input asp-for="PublishingDate" type="text" class="form-control form-control-solid js-datepicker" placeholder="Publishing Date" />
                                </div>
                                <span asp-validation-for="PublishingDate" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row ">
                        <div class="col">
                            <div class="mb-5">
                                <div class="form-check form-switch form-check-custom form-check-solid">
                                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsAvailableForRental">
                                    <label class="form-check-label" asp-for="IsAvailableForRental"></label>
                                </div>
                                <span asp-validation-for="IsAvailableForRental" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="mb-5">
                                <div class="form-floating mb-2">
                                    <input asp-for="Hall" type="text" class="form-control form-control-solid" placeholder=" " />
                                    <label asp-for="Hall"></label>
                                </div>
                                <span asp-validation-for="Hall" class="text-danger d-block"></span>
                            </div>
                        </div>
                    </div>
                    
                </div>
                <div class="col-md-7">
                    <div class="mb-5">
                        <div class="form-floating mb-2">
                            <textarea class="form-control form-control-solid js-tinymce" placeholder=" " asp-for="Description"></textarea>
                            <label asp-for="Description">Comments</label>
                            <span asp-validation-for="Description" class="text-danger d-block"></span>
                        </div>
                    </div>
                </div>
            </div>


          
 
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary " data-kt-indicator="off">
                <span class="indicator-label">
                    Save
                </span>
                <span class="indicator-progress">
                    Please wait... <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                </span>
            </button>
            <a class="btn btn-light-danger ms-3" asp-action="Index">Cancel</a>
        </div>
    
    </div>
</form>


@section Scripts {
    <script src="~/assets/plugins/tinymce/tinymce.bundle.js"></script>
    <partial name="_ValidationScriptsPartial" />
}

       