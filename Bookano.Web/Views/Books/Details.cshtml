@model BookViewModel

@{
    ViewData["Title"] = Model.Title;
}


<div class="content flex-column-fluid  " id="kt_content">

    <!--begin::Navbar-->
    <div class="card mb-9">
        <div class="card-body pt-9 pb-0">
            <!--begin::Details-->
            <div class="d-flex flex-wrap flex-sm-nowrap mb-6">
                <!--begin::Image-->
                <div class="d-flex flex-center flex-shrink-0 bg-light rounded w-100px h-100px w-lg-150px h-lg-175px me-7 mb-4">
                    <a class="d-block overlay" data-fslightbox href="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/books/no-image-cover.png" : Model.ImageUrl)">
                        <!--begin::Image-->
                        <img class=" overlay-wrapper w-100px h-150px " src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/books/no-image-cover.png" : Model.ImageUrl)" alt="@Model.Title" />
                        <!--end::Image-->
                        <!--begin::Action-->
                        <div class="overlay-layer card-rounded bg-dark bg-opacity-25 shadow">
                            <i class="bi bi-eye-fill text-white fs-3x"></i>
                        </div>
                        <!--end::Action-->
                    </a>
                </div>
                <!--end::Image-->
                <!--begin::Wrapper-->
                <div class="flex-grow-1">
                    <!--begin::Head-->
                    <div class="d-flex justify-content-between align-items-start flex-wrap ">
                        <!--begin::Details-->
                        <div class="d-flex flex-column">
                            <!--begin::Status-->
                            <div class="d-flex align-items-center mb-1">
                                <a href="javascript:;"
                                       class="text-gray-800 text-hover-primary fs-2 fw-bold me-3">
                                    @Model.Title
                                </a>
                                @{
                                    var (badge, text) = Model.IsDeleted ? ("danger", "Deleted")
                                        : (Model.IsAvailableForRental ? ("success", "Available for rental")
                                        : ("warning", "Not available for rental"));
                                }
                                <span class="badge badge-light-@badge me-auto">@text</span>
                            </div>
                            <!--end::Status-->
                            <!--begin::Description-->
                            <div class="d-flex flex-wrap fw-semibold mb-1 fs-5 text-gray-500">
                                <i class="fa-solid fa-user-pen align-self-center fs-7"></i>
                                @foreach (var author in Model.Authors)
                                {
                                    <span class="badge badge-light-primary ms-2 ">@author</span>
                                }
                            </div>
                            <div class="d-flex flex-wrap   mb-4 fs-7 text-gray-500">
                                @Model.Publisher
                            </div>
                            <!--end::Description-->
                        </div>
                        <!--end::Details-->
                        <!--begin::Actions-->
                        <div class="d-flex mb-4">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-md btn-primary me-3">
                                <i class="fa-solid fa-pen-to-square"></i>
                                Edit
                            </a>
                        </div>
                        <!--end::Actions-->
                    </div>
                    <!--end::Head-->
                    <!--begin::Info-->
                    <div class="d-flex flex-wrap justify-content-start">
                        <!--begin::Stats-->
                        <div class="d-flex flex-wrap">
                            <!--begin::Stat-->
                            <div class="border border-gray-500 border-dashed rounded min-w-125px py-3 px-4 me-6 mb-3">
                                <!--begin::Number-->
                                
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-calendar-date-fill text-primary mb-2 me-2"></i>
                                    <div class="fs-7 fw-bold mb-1">@Model.PublishingDate.ToString("dd MMM, yyyy")</div>
                                </div>
                                <!--end::Number-->
                                <!--begin::Label-->
                                <div class="fw-semibold fs-7 text-gray-500">Publishing Date</div>
                                <!--end::Label-->
                            </div>
                            <!--end::Stat-->
                            <!--begin::Stat-->
                            <div class="border border-gray-500 border-dashed rounded min-w-125px py-3 px-4 me-6 mb-3">
                                <!--begin::Number-->
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-calendar-date-fill text-primary mb-2 me-2"></i>
                                    <div class="fs-7 fw-bold mb-1">@Model.CreatedOnUtc.ToString("dd MMM, yyyy")</div>
                                </div>
                                <!--end::Number-->
                                <!--begin::Label-->
                                <div class="fw-semibold fs-7 text-gray-500">Added Date</div>
                                <!--end::Label-->
                            </div>
                            <!--end::Stat-->
                            <!--begin::Stat-->
                            <div class="border border-gray-500 border-dashed rounded min-w-125px py-3 px-4 me-6 mb-3">
                                <!--begin::Number-->
                                <div class="d-flex align-items-center">
                                    <i class="fa-regular fa-copy text-primary me-2"></i>
                                    <div class="fs-7 fw-bold" data-kt-countup="true"
                                         data-kt-countup-value="7">
                                        0
                                    </div>
                                </div>
                                <!--end::Number-->
                                <!--begin::Label-->
                                <div class="fw-semibold fs-7 text-gray-500">Copies</div>
                                <!--end::Label-->
                            </div>
                            <!--end::Stat-->
                        </div>
                        <!--begin::categories-->
                        <div class="align-self-end pb-3">
                            @foreach (var category in Model.Categories)
                            {
                                <span class="badge badge-light-info me-2">@category</span>
                            }
                        </div>
                        <!--end::categories-->
                    </div>
                    <!--end::Info-->
                </div>
                <!--end::Wrapper-->
            </div>
            <!--end::Details-->

            <div class="separator"></div>

            <!--begin::Nav-->
            <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold">
                
                <!--end::Nav item-->
                <!--begin::Nav item-->
                <li class="nav-item">
                    <a class="nav-link text-active-primary py-5 me-6 active " data-bs-toggle="tab"
                           href="#Description">
                        Description
                    </a>
                </li>
                <!--end::Nav item-->
                <!--begin::Nav item-->
                <li class="nav-item">
                    <a class="nav-link text-active-primary py-5 me-6 " data-bs-toggle="tab"
                           href="#Copies">
                        Copies
                    </a>
                </li>
                <!--end::Nav item-->
            </ul>
            <!--end::Nav-->
        </div>
    </div>
    <!--end::Navbar-->
    <!--begin::Card-->
    <div class="tab-content " style="max-width: 1510px">
        <div id="Description" class="card tab-pane fade show active">
            <!--begin::Card header-->
            <div class="card-header">
                <!--begin::Card title-->
                <div class="card-title fs-3 fw-bold">Description</div>
                <!--end::Card title-->
            </div>
            <!--end::Card header-->
            <!--begin::Card body-->
            <div class="card-body" style="min-width: 0; word-break: break-word; overflow-wrap: break-word;">
               
                @Html.Raw(Model.Description)
            </div>
            <!--end::Card body-->
        </div>
        <div id="Copies" class="card tab-pane fade">
            <!--begin::Card header-->
            <div class="card-header">
                <!--begin::Card title-->
                <div class="card-title fs-3 fw-bold">Copies</div>
                <!--end::Card title-->
            </div>
            <!--end::Card header-->
            <!--begin::Card body-->
            <div class="card-body ">
                Copies
            </div>
            <!--end::Card body-->
        </div>
    </div>
    <!--end::Card-->
</div>
@section Plugins {
    <script src="~/assets/plugins/fslightbox/fslightbox.bundle.js"></script>
}