@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!--begin::Row-->
<div class="row g-5 gx-xl-10 mb-5 mb-xl-10">
    <!--begin::Col-->
    <div class="col">
        <!--begin::Engage widget 6-->
        <div class="card rounded-4 card-shadow flex-grow-1 bgi-no-repeat bgi-size-contain bgi-position-x-end h-xl-100"
             style="background-color:#020202; background-image:url('assets/imgs/books-bg.webp'); background-size:cover;">
            <!--begin::Body-->
            <div class="card-body d-flex justify-content-between flex-column p-6 p-md-10 ps-xl-18">
                <!--begin::Heading-->
                <div class="mb-10 mb-xl-20 p-5 p-md-8 glass w-fit-content bg-dark bg-opacity-25 border border-white border-opacity-25">
                    <!--begin::Title-->
                    <h3 class="fw-bold text-white fs-2x fs-md-4x mb-4 mb-md-5 ms-n1 custom-header">Bookano</h3>
                    <!--end::Title-->
                    <!--begin::Description-->
                    <span class="fw-bold text-white fs-6 fs-md-4 mb-5 mb-md-8 d-block lh-2">Adventures await where ink meets your imagination.</span>
                    <!--end::Description-->
                    <!--begin::Items-->
                    <div class="d-flex flex-wrap align-items-center gap-4">
                        <!--begin::Item-->
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-book-open-reader text-white fs-3 fs-md-2 me-2"></i>
                            <span class="fw-semibold text-white fs-7 fs-md-6">@Model.NumberOfCopies+ books</span>
                        </div>
                        <!--end::Item-->
                        <!--begin::Item-->
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-address-card text-white fs-3 fs-md-2 me-2"></i>
                            <span class="fw-semibold text-white fs-7 fs-md-6">@Model.NumberOfSubscribers members</span>
                        </div>
                        <!--end::Item-->
                    </div>
                    <!--end::Items-->
                </div>
                <!--end::Heading-->
            </div>
            <!--end::Body-->
        </div>
        <!--end::Engage widget 6-->
    </div>
    <!--end::Col-->
</div>
<!--end::Row-->
<!--begin::Row-->
<div class="row g-5 g-xl-10 mb-5 mb-xl-10">
    <!--begin::Col-->
    <div class="col-12 col-lg-7">
        <!--begin::Player widget 1-->
        <div class="card card-flush h-lg-100">
            <!--begin::Header-->
            <div class="card-header pt-7">
                <!--begin::Title-->
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-900">Recently Added Books</span>
                </h3>
                <!--end::Title-->
            </div>
            <!--end::Header-->
            <!--begin::Card body-->
            <div class="card-body pt-7">
                <!--begin::Row-->
                <div class="row g-4 g-xl-9 mb-5 mb-xl-9">
                    @foreach (var book in Model.RecentlyAddedBooks)
                    {
                        <div class="col-6 col-sm-6 col-md-4 col-lg-6 col-xl-3">
                            <div class="card border-0 bg-transparent h-100 transition-all">
                                <!-- Book Image -->
                                <div class="overflow-hidden rounded-4 shadow-sm">
                                    <img src="@(book.ImageUrl ?? "/images/books/no-image-cover.png")"
                                         alt="@book.Title"
                                         class="img-fluid w-100 object-fit-cover h-200px h-sm-220px h-md-250px"
                                         style="transition: 0.4s;">
                                </div>
                                <!-- Book Info -->
                                <div class="pt-3">
                                    <h5 class="fw-bold text-dark text-truncate mb-1 fs-7 fs-md-6">@book.Title</h5>
                                    <p class="text-muted fw-semibold mb-0 small">@(string.Join(", ", book.Authors))</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <!--end::Row-->
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Player widget 1-->
    </div>
    <!--end::Col-->
    <!--begin::Col-->
    <div class="col-12 col-lg-5">
        <!--begin::List widget 24-->
        <div class="card h-lg-100" id="kt_list_widget_24">
            <!--begin::Header-->
            <div class="card-header border-0 pt-5">
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Most rented Books</span>
                </h3>
            </div>
            <!--end::Header-->
            <!--begin::Body-->
            <div class="card-body pt-6">
                @foreach (var book in Model.TopRentedBooks)
                {
                    <!--begin::Item-->
                    <div class="d-flex flex-stack">
                        <!--begin::Symbol-->
                        <div class="symbol symbol-50px symbol-md-60px me-3 me-md-4">
                            <img src="@(book.ImageUrl ?? "/images/books/no-image-cover.png")"
                                 alt="@book.Title"
                                 class="h-60px h-md-100px">
                        </div>
                        <!--end::Symbol-->
                        <!--begin::Section-->
                        <div class="d-flex align-items-center flex-row-fluid flex-wrap">
                            <!--begin::Author-->
                            <div class="flex-grow-1 me-2 min-w-0">
                                <h5 class="text-gray-800 text-hover-primary fs-7 fs-md-5 fw-bolder text-truncate mb-1">@book.Title</h5>
                                <span class="text-gray-500 fw-semibold d-block fs-7 fs-md-6 text-truncate">@(string.Join(", ", book.Authors))</span>
                            </div>
                            <!--end::Author-->
                        </div>
                        <!--end::Section-->
                    </div>
                    <!--end::Item-->
                    @if (book != Model.TopRentedBooks.Last())
                    {
                        <!--begin::Separator-->
                        <div class="separator separator-dashed my-4 my-md-5"></div>
                        <!--end::Separator-->
                    }
                }
            </div>
            <!--end::Body-->
        </div>
        <!--end::List widget 24-->
    </div>
    <!--end::Col-->
</div>
<!--end::Row-->
<!--begin::Row-->
<div class="row g-5 g-xl-10">
    <!--begin::Col-->
    <div class="col-12 col-lg-7">
        <!--begin::Table widget 13-->
        <div class="card card-flush h-lg-100">
            <!--begin::Header-->
            <div class="card-header pt-7">
                <!--begin::Title-->
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Rentals</span>
                    <span class="text-gray-500 mt-1 fw-semibold fs-6">Per Day</span>
                </h3>
                <!--end::Title-->
                <!--begin::Toolbar-->
                <div class="card-toolbar">
                    <div data-kt-daterangepicker="true"
                         data-kt-daterangepicker-opens="left"
                         class="btn btn-sm btn-light d-flex align-items-center px-3 px-md-4"
                         data-kt-initialized="1"
                         id="DateRange">
                        <div class="text-gray-600 fw-bold d-none d-sm-block">17 Apr 2026 - 16 May 2026</div>
                        <i class="fa-solid fa-calendar ms-0 ms-sm-3 fa-xl"></i>
                    </div>
                </div>
                <!--end::Toolbar-->
            </div>
            <!--end::Header-->
            <!--begin::Body-->
            <div class="card-body pt-3 pb-4">
                <div id="RentalsPerDay" style="min-height:220px; height:clamp(220px, 40vw, 350px);"></div>
            </div>
            <!--end::Body-->
        </div>
        <!--end::Table widget 13-->
    </div>
    <!--end::Col-->
    <!--begin::Col-->
    <div class="col-12 col-lg-5">
        <div class="card card-flush h-lg-100">
            <!--begin::Header-->
            <div class="card-header pt-7">
                <!--begin::Title-->
                <h3 class="card-title align-items-start flex-column">
                    <span class="card-label fw-bold text-gray-800">Members</span>
                    <span class="text-gray-500 mt-1 fw-semibold fs-6">Per City</span>
                </h3>
                <!--end::Title-->
            </div>
            <!--end::Header-->
            <!--begin::Body-->
            <div class="card-body pt-3 pb-4">
                <canvas id="SubscribersPerGovernorate" class="mh-400px w-100"></canvas>
            </div>
            <!--end::Body-->
        </div>
    </div>
    <!--end::Col-->
</div>
<!--end::Row-->
@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}