@model BookCopyFormViewModel


<form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")"
      data-ajax-method="post"
      data-ajax="true"
      data-ajax-success="onModalSuccess"
      data-ajax-failure="showErrorMessage"
      data-ajax-complete="onModalComplete">

    <input type="hidden" asp-for="BookId" />
    @if (Model?.Id > 0)
    {
        <input type="hidden" asp-for="Id" />
    }
    <div class="row">
        <div class="col">
            <div class="form-floating mb-7">
                <input type="text"
                       class="form-control"
                       placeholder=" "
                       asp-for="EditionNumber"
                       value="@(Model!.Id > 0 ? Model.EditionNumber : string.Empty)" />
                <label asp-for="EditionNumber"></label>
                <span class="text-danger" asp-validation-for="EditionNumber"></span>
            </div>
            @if (Model!.ShowRentalInput)
            {
                    <div class="form-check form-switch form-check-custom form-check-solid mb-4">
                        <input class="form-check-input" type="checkbox" role="switch" asp-for="IsAvailableForRental">
                        <label class="form-check-label" asp-for="IsAvailableForRental"></label>
                    </div>
                    <span asp-validation-for="IsAvailableForRental" class="text-danger d-block"></span>
            }
            <partial name="_ModalFooter" />
        </div>
    </div>
</form>

