@model ResetPasswordFormViewModel


<form asp-action="ResetPassword"
      data-ajax-method="post"
      data-ajax="true"
      data-ajax-success="onModalSuccess"
      data-ajax-failure="showErrorMessage"
      data-ajax-complete="onModalComplete">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col">
            <div class="form-floating mb-7">
                <input type="password" class="form-control form-control-solid" placeholder=" " asp-for="Password" />
                <label asp-for="Password"></label>
                <span class="text-danger" asp-validation-for="Password"></span>
            </div>
            <div class="form-floating mb-7">
                <input type="password" class="form-control form-control-solid" placeholder=" " asp-for="ConfirmPassword" />
                <label asp-for="ConfirmPassword"></label>
                <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
            </div>
            <partial name="_ModalFooter" />
        </div>
    </div>
</form>