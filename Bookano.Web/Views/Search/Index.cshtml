@model SearchFormViewModel

@{
    ViewData["Title"] = "Find a book";
    var isAutheticated = User.Identity!.IsAuthenticated;
}

@section Styles {
    <link href="~/css/typeahead.css" rel="stylesheet" />
}

<div class="@(isAutheticated ? "m-0" : "m-10")">
    @if (!isAutheticated)
    {
        <ul class="breadcrumb breadcrumb-dot fw-semibold text-gray-600 fs-7 mb-5">
            <li class="breadcrumb-item text-gray-600">
                <a href="/" class="text-gray-600 text-hover-primary">Home</a>
            </li>
            <li class="breadcrumb-item text-gray-500">
                Find a book
            </li>
        </ul>
    }

    <div class="card mb-12">
        <!--begin::Hero body-->
        <div class="card-body flex-column p-1 pt-4  p-md-5 min-h-400px">
            <!--begin::Hero content-->
            <div class="d-flex flex-column  flex-sm-row align-items-center h-lg-300px p-5 p-lg-15">
                <!--begin::Wrapper-->
                <div class="d-flex flex-column align-items-start justift-content-center flex-equal me-sm-5 mb-10">
                    <!--begin::Title-->
                    <h1 class="fw-bold fs-4 fs-lg-1 text-gray-800 mb-5 mb-lg-10">Find a book?</h1>
                    <!--end::Title-->
                    <!--begin::Input group-->
                    <div class="position-relative w-100">
                        <i class=" fa-solid fa-magnifying-glass fs-3 text-gray-500 position-absolute top-50 translate-middle ms-6 z-index-3" ></i>
                        <input type="text" class="form-control fs-4 py-4 ps-14 text-gray-700 placeholder-gray-500 mw-500px" id="Search" placeholder="Search by book title or author name or ISBN...">
                    </div>
                    <!--end::Input group-->
                </div>
                <!--end::Wrapper-->
                <!--begin::Wrapper-->
                <div class="flex-equal d-flex justify-content-center align-items-end ms-5">
                    <!--begin::Illustration-->
                    <img src="~/assets/imgs/find_book.png" alt="" class="mw-100 mh-200px mh-lg-400px mb-lg-n12">
                    <!--end::Illustration-->
                </div>
                <!--end::Wrapper-->
            </div>
            <!--end::Hero content-->
        </div>
        <!--end::Hero body-->
    </div>
</div>


@section Plugins{
    <script src="~/lib/typeahead.js/typeahead.bundle.min.js"></script>
    <script src="~/lib/handlebars.js/handlebars.min.js"></script>
}

@section Scripts{
    <script src="~/js/search.js" asp-append-version="true"></script>
}