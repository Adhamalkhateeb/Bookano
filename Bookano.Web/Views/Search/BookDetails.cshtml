@model BookViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/assets/plugins/datatables/datatables.bundle.css" />
}

<div class="content flex-column-fluid p-10" id="kt_content">
    @if (!User.Identity!.IsAuthenticated)
    {
        <ul class="breadcrumb breadcrumb-dot fw-semibold text-gray-600 fs-7 mb-5">
            <li class="breadcrumb-item text-gray-600">
                <a href="/" class="text-gray-600 text-hover-primary">Home</a>
            </li>
            <li class="breadcrumb-item text-gray-600">
                <a asp-controller="Search" asp-action="Index" class="text-gray-600 text-hover-primary">Find a book</a>
            </li>
            <li class="breadcrumb-item text-gray-500">
                @Model.Title
            </li>
        </ul>
    }

    <!--begin::Navbar-->
    <div class="card mb-9">
        <div class="card-body pt-9 pb-0">
            <!--begin::Details-->
            <div class="d-flex flex-column flex-md-row mb-6">
                <!--begin::Image-->
                <div class="d-flex flex-center flex-shrink-0 bg-light rounded w-100 h-175px w-md-150px h-md-200px me-md-7 mb-4 mx-auto mx-md-0">
                    <a class="d-block overlay" data-fslightbox href="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/books/no-image-cover.png" : Model.ImageUrl)">
                        <img class="overlay-wrapper w-100px h-150px" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/books/no-image-cover.png" : Model.ImageUrl)" alt="@Model.Title" />
                        <div class="overlay-layer card-rounded bg-dark bg-opacity-25 shadow">
                            <i class="bi bi-eye-fill text-white fs-3x"></i>
                        </div>
                    </a>
                </div>
                <!--end::Image-->
                <!--begin::Wrapper-->
                <div class="flex-grow-1">
                    <!--begin::Head-->
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start">
                        <!--begin::Details-->
                        <div class="d-flex flex-column w-100">
                            <!--begin::Status-->
                            <div class="d-flex align-items-center flex-wrap mb-1">
                                <a href="javascript:;" class="text-gray-800 text-hover-primary fs-2 fw-bold me-3">
                                    @Model.Title
                                </a>
                                @{
                                    var (badge, text) = Model.IsDeleted ? ("danger", "Deleted")
                                        : (Model.IsAvailableForRental ? ("success", "Available for rental")
                                        : ("warning", "Not available for rental"));
                                }
                                <span class="badge badge-light-@badge my-1">@text</span>
                            </div>

                            <!--begin::Description-->
                            <div class="d-flex flex-wrap fw-semibold mb-1 fs-5 text-gray-500">
                                <i class="fa-solid fa-user-pen align-self-center fs-7"></i>
                                @foreach (var author in Model.Authors)
                                {
                                    <span class="badge badge-light-primary ms-2 my-1">@author</span>
                                }
                            </div>
                            <div class="d-flex flex-wrap mb-4 fs-7 text-gray-500">
                                @Model.Publisher
                            </div>
                        </div>

                    </div>

                    <!--begin::Stats-->
                    <div class="d-flex flex-wrap justify-content-start">
                        <div class="d-flex flex-wrap w-100 w-md-auto">
                            <!--Stat: Publishing Date-->
                            <div class="border border-gray-500 border-dashed rounded min-w-125px py-3 px-4 me-md-6 me-2 mb-3 flex-grow-1 flex-md-grow-0">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-calendar-date-fill text-primary mb-2 me-2"></i>
                                    <div class="fs-7 fw-bold mb-1">@Model.PublishingDate.ToString("dd MMM, yyyy")</div>
                                </div>
                                <div class="fw-semibold fs-7 text-gray-500">Publishing Date</div>
                            </div>
                            <!--Stat: Added Date-->
                            <div class="border border-gray-500 border-dashed rounded min-w-125px py-3 px-4 me-md-6 me-2 mb-3 flex-grow-1 flex-md-grow-0">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-calendar-date-fill text-primary mb-2 me-2"></i>
                                    <div class="fs-7 fw-bold mb-1">@Model.CreatedOnUtc.ToString("dd MMM, yyyy")</div>
                                </div>
                                <div class="fw-semibold fs-7 text-gray-500">Added Date</div>
                            </div>
                            <!--Stat: Copies-->
                            <div class="border border-gray-500 border-dashed rounded min-w-125px py-3 px-4 me-md-6 me-2 mb-3 flex-grow-1 flex-md-grow-0">
                                <div class="d-flex align-items-center">
                                    <i class="fa-regular fa-copy text-primary me-2"></i>
                                    <div id="CopiesCount" class="fs-7 fw-bold" data-kt-countup="true" data-kt-countup-value="@Model.Copies.Count()">
                                        @Model.Copies.Count()
                                    </div>
                                </div>
                                <div class="fw-semibold fs-7 text-gray-500">Copies</div>
                            </div>
                        </div>
                    </div>

                    <!--begin::Categories-->
                    <div class="d-flex flex-wrap align-items-center pb-2">
                        <span class="text-dark me-2">Categories: </span>
                        @foreach (var category in Model.Categories)
                        {
                            <span class="badge badge-light-info me-2 my-1">@category</span>
                        }
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <span>ISBN:</span>
                        <span id="isbnValue" class="text-primary fw-bolder cursor-pointer" onclick="copyISBN(this)" title="Click to copy">
                            @Model.Isbn
                        </span>
                    </div>
                </div>
                <!--end::Wrapper-->
            </div>
            <!--end::Details-->

            <div class="separator"></div>

            <!--begin::Nav-->
            <ul class="nav nav-stretch nav-line-tabs nav-line-tabs-2x border-transparent fs-5 fw-bold  flex-nowrap">
                <li class="nav-item">
                    <a class="nav-link text-active-primary py-5 me-6 active" data-bs-toggle="tab" href="#Description">Description</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-active-primary py-5 me-6" data-bs-toggle="tab" href="#Copies">Copies</a>
                </li>
            </ul>
        </div>
    </div>

    <!--begin::Tab Content-->
    <div class="tab-content mw-100">
        <div id="Description" class="card tab-pane fade show active">
            <div class="card-header">
                <div class="card-title fs-3 fw-bold">Description</div>
            </div>
            <div class="card-body" style="word-break: break-word; overflow-wrap: break-word;">
                @Html.Raw(Model.Description)
            </div>
        </div>
        <div id="Copies" class="card tab-pane fade">
            <div class="card-header">
                <div class="card-title fs-3 fw-bold">Copies</div>
            </div>
            <div class="card-body">
                <div class="@(!Model.Copies.Any() ? "d-none" : string.Empty) table-responsive">
                    <table class="table table-row-dashed table-row-gray-300 gy-2 align-middle js-datatable">
                        <thead>
                            <tr class="fw-bold fs-6 text-gray-600 text-uppercase">
                                <th>Serial Number</th>
                                <th>Edition</th>
                                <th>Rental</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var copy in Model.Copies)
                            {
                                <tr>
                                    <td>@copy.SerialNumber</td>
                                    <td>@copy.SerialNumber</td>
                                    <td>
                                        <span class="badge badge-light-@(copy.IsAvailableForRental ? "success" : "warning")">
                                            @(copy.IsAvailableForRental ? "Available" : "Not Available")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="@(Model.Copies.Any() ? "d-none" : string.Empty) alert alert-dismissible bg-light-warning border border-warning border-3 border-dashed d-flex flex-column flex-sm-row w-100 p-5 mb-10 js-alert">
                    <i class="bi bi-exclamation-octagon-fill me-5 text-warning align-self-center fs-1"></i>
                    <div class="d-flex flex-column pe-0 pe-sm-10">
                        <h5 class="mt-2">No copies available for this Book</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Plugins {
    <script src="~/assets/plugins/fslightbox/fslightbox.bundle.js"></script>
    <script src="~/assets/plugins/datatables/datatables.bundle.js"></script>
}

@section Scripts {
    <script src="~/js/book-details.js" asp-append-version="true"></script>
}